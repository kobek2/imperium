# Supabase (https://supabase.com/dashboard → Project Settings → API)
# Copy "Project URL" exactly. Do not guess the hostname from the anon JWT — if it
# is wrong, the browser shows DNS_PROBE_FINISHED_NXDOMAIN.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Discord OAuth: enable provider in Supabase Auth > Providers > Discord
# Redirect URL in Discord Developer Portal:
#   https://<project-ref>.supabase.co/auth/v1/callback

# Bot (separate process in /bot) — syncs Discord roles → government_role_grants
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
# Dashboard → API: use the secret/service key (sb_secret_... or legacy service_role JWT). Never NEXT_PUBLIC_*.
# When set on the server, presidential electoral bundle reads use it so the map matches Postgres (RLS-safe).
SUPABASE_SERVICE_ROLE_KEY=

# Vercel cron: GET /api/calendar-tick with Authorization: Bearer <this value>
CRON_SECRET=

# Crisis newsroom: AI-generated wire follow-ups after executive orders, statements, and legislation
OPENAI_API_KEY=
# Optional override (default: gpt-4o-mini)
# OPENAI_CRISIS_MODEL=gpt-4o-mini
# Same as NEXT_PUBLIC_SUPABASE_URL (for bot only)
SUPABASE_URL=
